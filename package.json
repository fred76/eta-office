{
  "name": "eta-office",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node dist-server/index.js",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "ng serve --proxy-config proxy.conf.json",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "ng build --configuration production",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "test": "ng test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:admin": "tsx server/scripts/seed-admin.ts",
    "seed:ship": "tsx server/scripts/seed-ship.ts"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.21",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@types/dotenv": "^6.1.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "daisyui": "^4.12.24",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "echarts": "^6.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "multer": "^2.1.1",
    "ngx-echarts": "^19.0.0",
    "node-fetch": "^3.3.2",
    "pino": "^10.3.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.24",
    "@angular/cli": "^19.2.24",
    "@angular/compiler-cli": "^19.2.0",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jasmine": "~5.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2"
  }
}
